theme = Solarized Dark Patched
background-opacity = 0.7
background-blur-radius = 20
background = "#031219"
font-family = "PlemolJP Console NF"
cursor-style = block
cursor-style-blink = false
macos-option-as-alt = left
shell-integration-features = no-cursor
macos-titlebar-style = tabs
window-padding-x = 10
window-padding-y = 0

keybind = ctrl+a>a=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.3

keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down
keybind = cmd+ctrl+left=resize_split:left,20
keybind = cmd+ctrl+right=resize_split:right,20
keybind = cmd+ctrl+up=resize_split:up,20
keybind = cmd+ctrl+down=resize_split:down,20

keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab